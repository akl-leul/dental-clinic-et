generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Appointment {
  id         Int      @id @default(autoincrement())
  name       String
  email      String
  phone      String
  treatment  String
  date       DateTime
  time       String
  notes      String?
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())
}
